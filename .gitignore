# MINESWEEPER
# Exclusion patterns for local development and system-generated artifacts

# System files
[Tt]humbs.db
[Dd]esktop.ini
.DS_Store

# Environment and workspace configuration
.vscode/
.idea/
*.swp
*.swo
*~

# Dependency and build directories
node_modules/
dist/
build/
.env
.npm
.eslintcache

# Temporary and log files
Source Code/temp/
Source Code/logs/
*.tmp
*.log
*.bak
*.sav
*.old

# Documentation and archive artifacts
DOCUMENTATION.md.bak
README.md.bak
*.zip
*.tar.gz
*.rar
*.7z
